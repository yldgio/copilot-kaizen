{
  "version": 1,
  "description": "Continuous-improvement memory layer — auto-learning hooks for Copilot CLI",
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": ".github/hooks/kaizen/kaizen.sh sessionStart",
        "powershell": "pwsh -NoProfile -File .github/hooks/kaizen/kaizen.ps1 -Event sessionStart",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": ".github/hooks/kaizen/kaizen.sh sessionEnd",
        "powershell": "pwsh -NoProfile -File .github/hooks/kaizen/kaizen.ps1 -Event sessionEnd",
        "timeoutSec": 15
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/kaizen/kaizen.sh preToolUse",
        "powershell": "pwsh -NoProfile -File .github/hooks/kaizen/kaizen.ps1 -Event preToolUse",
        "timeoutSec": 2
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/kaizen/kaizen.sh postToolUse",
        "powershell": "pwsh -NoProfile -File .github/hooks/kaizen/kaizen.ps1 -Event postToolUse",
        "timeoutSec": 5
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": ".github/hooks/kaizen/kaizen.sh errorOccurred",
        "powershell": "pwsh -NoProfile -File .github/hooks/kaizen/kaizen.ps1 -Event errorOccurred",
        "timeoutSec": 5
      }
    ]
  }
}
