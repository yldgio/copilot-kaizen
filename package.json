{
  "name": "@yldgio/copilot-kaizen",
  "version": "1.0.2",
  "description": "Continuous-improvement memory layer for GitHub Copilot CLI — auto-learning hooks, context injection, and synthesis",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "kaizen": "./bin/kaizen.mjs"
  },
  "exports": {
    ".": "./kaizen.mjs",
    "./extension": "./extension.mjs",
    "./lib/db": "./lib/db.mjs",
    "./lib/inject": "./lib/inject.mjs",
    "./lib/synthesize": "./lib/synthesize.mjs",
    "./lib/compress": "./lib/compress.mjs",
    "./lib/project": "./lib/project.mjs"
  },
  "files": [
    "kaizen.mjs",
    "extension.mjs",
    "lib/",
    "bin/",
    "hooks/",
    "templates/",
    "skills/",
    "hooks.json",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {},
  "scripts": {
    "test": "node --test test/",
    "lint": "echo 'no linter configured'",
    "prepublishOnly": "node -e \"import('./lib/db.mjs').then(m => { const db = m.openDb(); db.close(); console.log('DB OK') })\""
  },
  "keywords": [
    "copilot",
    "copilot-cli",
    "kaizen",
    "hooks",
    "memory",
    "context-injection",
    "continuous-improvement",
    "ai-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yldgio/copilot-kaizen.git"
  },
  "homepage": "https://github.com/yldgio/copilot-kaizen#readme",
  "bugs": {
    "url": "https://github.com/yldgio/copilot-kaizen/issues"
  },
  "author": "AGIC",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
